{
  "name": "@johanthoren/jeff",
  "version": "1.3.3",
  "description": "jeff: a quality brigade for coding agents (pi shell core)",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["pi-package"],
  "files": [
    ".claude-plugin",
    "AGENTS.md",
    "agents",
    "assets/jeff.png",
    "hooks",
    "NOTICE",
    "skills",
    "src/**/*.js",
    "!src/**/*.test.js"
  ],
  "pi": {
    "extensions": ["./src/pi/extension.js"],
    "skills": ["./skills"]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "20.19.43",
    "typescript": "5.9.3"
  }
}
